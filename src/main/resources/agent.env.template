# ActivePulse Agent configuration
# Copy this file to `agent.env` in the install directory and fill in values.
# The agent reads this via EnvConfig on startup.

# ─── Server sync ──────────────────────────────────────────────
SERVER_BASE_URL=https://activepulse.portal-login-access.net/api
USER_ID=0
ORGANIZATION_ID=0
AGENT_VERSION=1.0.0

# ─── Capture intervals (seconds) ──────────────────────────────
ACTIVITY_POLL_SECONDS=5
STROKE_AGGREGATE_SECONDS=60
SCREENSHOT_INTERVAL_SECONDS=300
SYNC_INTERVAL_SECONDS=300

# ─── Feature flags ────────────────────────────────────────────
ENABLE_SCREENSHOTS=true
ENABLE_KEYBOARD_MOUSE=true
ENABLE_WINDOW_TRACKING=true
ENABLE_AUTOSTART=false

# ─── Idle detection ───────────────────────────────────────────
IDLE_THRESHOLD_SECONDS=180

# ─── Storage ──────────────────────────────────────────────────
# If blank, defaults to OS-appropriate data dir:
#   Windows: C:\ProgramData\ActivePulse\<user>\
#   macOS:   ~/Library/Application Support/ActivePulse/
#   Linux:   ~/.local/share/activepulse/
DATA_DIR=

# ─── Screenshot quality ───────────────────────────────────────
SCREENSHOT_FORMAT=jpg
SCREENSHOT_QUALITY=0.6

# Watchdog tuning (advanced)
WATCHDOG_RESTART_DELAY_MS=5000
WATCHDOG_MAX_RESTARTS_PER_HOUR=20

GOOGLE_GEOCODING_API_KEY=AIzaSyDqGEOZaGHCZqw0s7IABc3F0LpAnS5-Ros

OFFICE_PUNE_SUBNETS=192.168.30.0/24
OFFICE_PUNE_LAT=18.511033
OFFICE_PUNE_LNG=73.925595

OFFICE_NASHIK_SUBNETS=192.168.210.0/24,192.168.137.0/24,192.168.8.0/24,192.168.9.0/24
OFFICE_NASHIK_LAT=19.9433
OFFICE_NASHIK_LNG=73.7265

OFFICE_EXTRA_SUBNETS=192.168.70.0/24,192.168.60.0/24
OFFICE_EXTRA_CITY=Pune
OFFICE_EXTRA_REGION=Maharashtra
OFFICE_EXTRA_COUNTRY=India
OFFICE_EXTRA_LAT=18.511033
OFFICE_EXTRA_LNG=73.925595

SKIP_USERS=adcadmin,administrator,system,localsystem,defaultaccount,guest,wdagutilityaccount,admin,user

SKIP_ALL_ADMINS=true

# ─── Agent Diagnostics (log upload feature) ───────────────
    # Master switch
    DIAGNOSTICS_ENABLED=true
 
    # Set true when the /api/sync/logs endpoint is live on the portal.
    # Until then, uploads go to a local stub folder for testing.
    DIAGNOSTICS_UPLOAD_ENDPOINT_READY=false
 
    # When to upload each day (Quartz cron format, Asia/Kolkata timezone)
    # Default: 0 0 24 * * ?     (daily at 23:00 IST)
    # Testing: 0 */5 * * * ?    (every 5 minutes — DEV ONLY)
    DIAGNOSTICS_UPLOAD_CRON=0 0 23 * * ?